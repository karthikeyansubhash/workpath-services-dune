<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="${PACMAN_READ_PROVIDERS_PERMISSION}" />
    <uses-permission android:name="${PACMAN_LIST_PACKAGES_PERMISSION}" />
    <uses-permission android:name="${PACMAN_PACKAGE_LIFECYCLE_EVENTS_PERMISSION}"/>
    <uses-permission android:name="${SERVICES_PERMISSION}" />
    <uses-permission android:name="${SYSTEM_ENABLED_PACKAGES_PERMISSION}" />
    <uses-permission android:name="${SYSTEM_PERMISSION}" />
    <application>
        <provider
            android:name=".provider.AccessoryLetContentProvider"
            android:authorities="com.hp.jetadvantage.link.authority.accessoryletcp"
            android:enabled="true"
            android:exported="true"/>

        <service android:name=".service.AccessoryNotificationService"
            android:exported="false"/>

        <receiver android:name=".receiver.WorkpathReadyReceiver"
            android:permission="${SYSTEM_PERMISSION}"
            android:exported="true">
            <intent-filter>
                <action android:name="${WORKPATH_SERVICE_READY}"/>
            </intent-filter>
        </receiver>
    </application>

</manifest>
