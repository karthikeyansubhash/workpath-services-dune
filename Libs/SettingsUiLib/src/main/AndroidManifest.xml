            android:windowSoftInputMode="adjustPan"
            android:configChanges="keyboard|keyboardHidden|screenSize|orientation"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar">
            <intent-filter>
                <action android:name="com.hp.jetadvantage.link.intent.action.SCANTO" />
                <action android:name="com.hp.jetadvantage.link.intent.action.PRINT" />
                <action android:name="com.hp.jetadvantage.link.intent.action.COPY" />
