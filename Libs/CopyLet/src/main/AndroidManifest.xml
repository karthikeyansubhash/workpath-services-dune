<manifest xmlns:tools="http://schemas.android.com/tools"
    xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="${SERVICES_PERMISSION}" />

    <application>
        <provider
            android:name="com.hp.jetadvantage.link.services.copylet.provider.OXPCopyletContentProvider"
            android:authorities="com.hp.jetadvantage.link.authority.oxp.copyletcp"
            android:exported="true"
            tools:ignore="Instantiatable" />

        <receiver
            android:name="com.hp.jetadvantage.link.services.copylet.receiver.OXPCopyletBroadcastReceiver">
            <intent-filter android:priority="1">
                <action android:name="com.hp.jetadvantage.link.intent.action.COPY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <receiver
            android:name="com.hp.jetadvantage.link.services.copylet.receiver.OXPCopyletReleaseBroadcastReceiver">
            <intent-filter android:priority="1">
                <action android:name="com.hp.jetadvantage.link.intent.action.RELEASE_COPY" />
                <category android:name="android.intent.category.DEFAULT" />
            </intent-filter>
        </receiver>

        <service android:name="com.hp.jetadvantage.link.services.copylet.service.CopyJobIntentService"
            android:permission="${SERVICES_PERMISSION}"
            android:exported="false">
            <intent-filter>
                <action android:name="com.hp.jetadvantage.link.intent.action.BASIC_API_CANCEL_COPY" />
            </intent-filter>
        </service>
    </application>

</manifest>
