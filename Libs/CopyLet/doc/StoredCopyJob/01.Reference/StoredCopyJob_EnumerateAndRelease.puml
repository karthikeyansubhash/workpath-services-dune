@startuml
title Stored Copy Job - Enumerate and Release Stored Copy Job
hide footbox
autonumber "<b>#."
skinparam sequenceArrowThickness 1
skinparam ArrowColor black
skinparam SequenceLifeLineBorderColor black
skinparam ParticipantBorderColor black
skinparam SequenceBoxBorderColor black
skinparam NoteBorderColor black
skinparam NoteFontSize 10  // Adjust the value as needed for smaller text

' This diagram illustrates the sequence of operations for releasing a stored copy job in the Workpath system.

' Participants
participant "Workpath App" as App
box "Workpath Services" #d6f5d6
participant "Copy Service" as CopyService #85e085
participant "Scan Service" as ScanService #85e085
participant "Job Service" as JobService #85e085
endbox

box "E2/Dune Platform" #b3d9ff
participant "E2 Copy Agent" as E2CopyAgent #66b3ff
participant "E2 Scan Agent" as E2ScanAgent #66b3ff
endbox

== Enumerate Stored Copy Jobs ==
App -> CopyService : enumerateStoredJob(Context, Result)
activate App
activate CopyService
CopyService -> E2CopyAgent : GET /ext/copy/v1/copyAgents/{agentId}/storedJobs?includeMembers
activate E2CopyAgent
E2CopyAgent --> CopyService : copyJobId
deactivate E2CopyAgent
note right CopyService #white
{"members": [{
    "jobId": "", 
    "jobName": "",
    "folderName": "",
    "jobTimestamp": "",
    "jobUserName": "",
    "totlaPages": 1},
    ...]}
end note
CopyService --> App : return List<StoredJobInfo>
deactivate App
deactivate CopyService

== Release a Stored Copy Job ==
' Release Stored Copy Job
App -> CopyService : releaseStoredJob(Context, StoredJobAttributes)
activate App
activate CopyService
note over CopyService #orange
Retrieve original copy options from StoredCopyJobMap <JobId, CopyJobIntent>
Create a copy ticket with the original copy options
end note
CopyService -> CopyService : Process copy ticket
CopyService --> App : return RID
deactivate App

' Copy Job Creation
CopyService -> E2CopyAgent : POST /ext/copy/v1/copyAgents/{agentId}/storedJobs/{jobId}/release
note right CopyService #white
{"copyOptions": {...}}
end note
activate E2CopyAgent
E2CopyAgent --> CopyService : copyJobId
deactivate E2CopyAgent
E2CopyAgent --> CopyService : copyNotification

' Job State and Data
CopyService -> JobService : CopyJobState, CopyJobData
deactivate CopyService
activate JobService

' Return Job State and Data
JobService --> App : CopyJobState, CopyJobData
deactivate JobService
deactivate App

@enduml


