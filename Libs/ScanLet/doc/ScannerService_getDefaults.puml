@startuml
title
<font size=20><b>ScannerService API : getDefaults() - Destination-based Defaults</b></font>
<font size=16>Support for Destination parameter (API 1: HTTP only, API 2: All destinations)</font>
end title

box "Workpath App" #FFFFFF
actor User as "Workpath ScanApp"
participant lib as "WorkpathLib"
end box
box "Workpath services " #C9FFB0
    'participant ScanBR as "ScanLet\nBroadcastReceiver"
    participant ScanCP as "ScanLet [provider]\nContentProvider"
    participant ScanAdapter as "ScanLet [adapter]\nScanDefaultOptionAdapter"
    'participant ScanIS as "[service]\nScanJob\nIntentService"
    'participant ScanSM as "[service]\nScanJob\nStateMachine"
    participant ScanDS as "DeviceService"

box "Workpath PacMan" #C9FFB0
    participant PacMan as "PacMan"
end box

box "Dune" #aliceblue
participant E2 as "    E2    "
end box

/'
rnote right of User
end note
'/

autonumber
== Get Scan Default Job Options ==
alt API 1 (Current) - getDefaults(Context, Result)
    User -> lib : ScannerService.\ngetDefaults(Context, Result)
    activate lib
    lib -> lib : Create request Bundle
    note right of lib #white
    Bundle : {"clientVersion" : 8}
    **// NO destination key**
    end note
    note right of lib #lightblue
    **API 1: No extra parameter**
    Defaults to: destination = HTTP
    end note
    lib [#0000FF]-> ScanCP : <<IPC>>\n ContentResolver.call(Uri, "get_defaults", Bundle)

else <color:red><b>API 2 (Future) - getDefaults(Context, Destination, Result)</b></color>
    User -> lib : ScannerService.\ngetDefaults(Context, <color:red><b>Destination</b></color>, Result)
    activate lib
    lib -> lib : Create request Bundle
    lib -> lib : <color:red><b>bundle.putSerializable("DESTINATION", destination)</b></color>
    note right of lib #lightgreen
    Bundle : {"clientVersion" : 8,
              <color:red><b>"DESTINATION": HTTP|FTP|NETWORK_FOLDER|ME|EMAIL|USB</b></color>}
    end note
    note right of lib #lightgreen
    <color:red><b>API 2: Destination-specific defaults</b></color>
    Uses specified destination
    end note
    lib [#0000FF]-> ScanCP : <<IPC>>\n ContentResolver.call(Uri, "get_defaults", Bundle)
end

activate ScanCP
ScanCP -> ScanCP : extract destination from Bundle
note right of ScanCP #lightyellow
<color:red><b>Extract destination with default:</b></color>

<color:red><b>Destination destination = 
    extras != null && extras.containsKey("DESTINATION")
        ? (Destination) extras.getSerializable("DESTINATION")
        : <color:blue><b>Global.Destination.HTTP</b></color>;  // default for API 1</b></color>

**API 1**: No DESTINATION key → defaults to <color:blue><b>Global.Destination.HTTP</b></color>
<color:red><b>API 2</b></color>: DESTINATION key present → use specified value
end note

ScanCP -> ScanAdapter : getDefaults(appPackageName, deviceService, <color:red><b>destination</b></color>)
activate ScanAdapter

note right of ScanAdapter #lightblue
<color:red><b>Updated method signature:</b></color>
public static String getDefaults(
    String packageName, 
    IDeviceScanJobService deviceService,
    <color:red><b>Destination destination</b></color>)
end note

ScanAdapter -> ScanAdapter : getDefaults(packageName, deviceService, <color:red><b>destination</b></color>)
activate ScanAdapter

ScanAdapter -> ScanDS : getProfile(appPackageName)
activate ScanDS
opt Not cached (Token & Profile)
